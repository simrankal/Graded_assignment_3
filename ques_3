from math import gcd

# ------------------------------------
# Primitive Root Check
# ------------------------------------
def prime_factors(n):
    factors = set()

    while n % 2 == 0:
        factors.add(2)
        n //= 2

    i = 3

    while i * i <= n:

        while n % i == 0:
            factors.add(i)
            n //= i

        i += 2

    if n > 2:
        factors.add(n)

    return factors


def primitive_root(alpha, p):

    phi = p - 1

    factors = prime_factors(phi)

    for factor in factors:
        if pow(alpha, phi // factor, p) == 1:
            return False

    return True


def diffie_hellman(p, alpha, a, b):

    print("="*60)

    print("Input")

    print("Prime (p) =", p)
    print("Primitive Root =", alpha)
    print("Alice Private =", a)
    print("Bob Private =", b)

    if not primitive_root(alpha, p):
        raise ValueError("alpha is not primitive root")

    if not (1 < a < p-1):
        raise ValueError("Invalid Alice private key")

    if not (1 < b < p-1):
        raise ValueError("Invalid Bob private key")

    A = pow(alpha, a, p)

    B = pow(alpha, b, p)

    KA = pow(B, a, p)

    KB = pow(A, b, p)

    print("\nComputed Values")
    print("-------------------------")
    print("Alice Public =", A)
    print("Bob Public =", B)
    print("Alice Shared Key =", KA)
    print("Bob Shared Key =", KB)

    print("\nKeys Match =", KA == KB)

    print("="*60)
    print()


