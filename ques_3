import math

# -----------------------------
# Helper Functions
# -----------------------------
def is_prime(n):
    if n <= 1:
        return False
    for i in range(2, int(n**0.5)+1):
        if n % i == 0:
            return False
    return True


def mod_inverse(e, phi):
    """
    Returns the smallest non-negative modular inverse
    such that (d * e) % phi == 1
    """
    for d in range(phi):
        if (d * e) % phi == 1:
            return d
    return None


def rsa(p, q, e, m):

    print("="*50)

    print(f"Input:")
    print(f"p = {p}")
    print(f"q = {q}")
    print(f"e = {e}")
    print(f"m = {m}")

    # Validate primes
    if not is_prime(p):
        raise ValueError("p is not prime")

    if not is_prime(q):
        raise ValueError("q is not prime")

    if p == q:
        raise ValueError("p and q must be distinct")

    n = p * q
    phi = (p-1)*(q-1)

    if not (1 < e < phi):
        raise ValueError("Invalid e")

    if math.gcd(e, phi) != 1:
        raise ValueError("e is not coprime with phi")

    if not (0 <= m < n):
        raise ValueError("Message must satisfy 0 <= m < n")

    d = mod_inverse(e, phi)

    if d is None:
        raise ValueError("No modular inverse exists")

    c = pow(m, e, n)

    recovered = pow(c, d, n)

    print("\nComputed Values")
    print("---------------------------")
    print("n =", n)
    print("phi(n) =", phi)
    print("Public exponent (e) =", e)
    print("Private exponent (d) =", d)
    print("Encrypted message =", c)
    print("Recovered message =", recovered)

    print("="*50)
    print()


